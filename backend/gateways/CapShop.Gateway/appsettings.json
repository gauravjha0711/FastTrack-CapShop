{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Ocelot": "Information"
    }
  },
  "AllowedHosts": "*",
  "GatewayRedisCache": {
    "Enabled": true,
    "ConnectionString": "localhost:6380",
    "InstanceName": "CapShopGateway:",
    "DefaultTtlSeconds": 120,
    "CacheOnlyAnonymousGetRequests": true,
    "MaxBodySizeBytes": 1048576,
    "CacheablePathPrefixes": [
      "/gateway/catalog",
      "/gateway/products",
      "/gateway/categories"
    ]
  }
}